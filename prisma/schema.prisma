generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String                   @map("password_hash")
  role                    String
  firstName               String?                  @map("first_name")
  lastName                String?                  @map("last_name")
  phoneNumber             String?                  @map("phone_number")
  profilePictureUrl       String?                  @map("profile_picture_url")
  address                 String?
  city                    String?
  state                   String?
  postalCode              String?                  @map("postal_code")
  country                 String?
  managerId               String?                  @map("manager_id")
  inviteCode              String?                  @unique @map("invite_code")
  referredById            String?                  @map("referred_by_id")
  status                  String                   @default("ACTIVE")
  isEmailVerified         Boolean                  @default(false) @map("is_email_verified")
  failedLoginAttempts     Int                      @default(0) @map("failed_login_attempts")
  lastFailedLogin         DateTime?                @map("last_failed_login")
  lockedUntil             DateTime?                @map("locked_until")
  requirePasswordReset    Boolean                  @default(false) @map("require_password_reset")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  ambassadorExpiry        DateTime?                @map("ambassador_expiry")
  ambassadorId            String?                  @unique @map("ambassador_id")
  teamLeaderId            String?                  @map("team_leader_id")
  activityLogs            ActivityLog[]
  childProfiles           ChildProfile[]
  commissions             Commission[]
  emailVerificationTokens EmailVerificationToken[]
  flipbookProgress        FlipbookProgress[]
  createdFlipbooks        Flipbook[]
  invitationsSent         Invitation[]             @relation("Inviter")
  orders                  Order[]                  @relation("CustomerOrders")
  referredOrders          Order[]                  @relation("AffiliateReferredOrders")
  passwordResetTokens     PasswordResetToken[]
  payoutRequests          PayoutRequest[]
  subscriptions           Subscription[]
  manager                 User?                    @relation("ManagerAffiliates", fields: [managerId], references: [id])
  affiliates              User[]                   @relation("ManagerAffiliates")
  referredBy              User?                    @relation("Referrals", fields: [referredById], references: [id])
  referrals               User[]                   @relation("Referrals")
  teamLeader              User?                    @relation("TeamLeaderAffiliates", fields: [teamLeaderId], references: [id])
  teamMembers             User[]                   @relation("TeamLeaderAffiliates")

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([managerId])
  @@index([referredById])
  @@index([inviteCode])
  @@index([ambassadorId])
  @@index([createdAt])
  @@map("users")
}

model Invitation {
  id           String    @id @default(uuid())
  inviterId    String    @map("inviter_id")
  inviteeEmail String    @map("invitee_email")
  inviteType   String    @map("invite_type")
  token        String    @unique
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  inviter      User      @relation("Inviter", fields: [inviterId], references: [id])

  @@map("invitations")
}

model Subscription {
  id               String           @id @default(uuid())
  customerId       String           @map("customer_id")
  planId           String           @map("plan_id")
  status           String
  paymentStatus    String           @default("PENDING") @map("payment_status")
  paymentReference String?          @map("payment_reference")
  startDate        DateTime         @map("start_date")
  endDate          DateTime         @map("end_date")
  autoRenew        Boolean          @default(false) @map("auto_renew")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  childProfileId   String?          @map("child_profile_id")
  gateway          String?          @default("PAYSTACK")
  currency         String?          @default("GHS")
  childProfile     ChildProfile?    @relation(fields: [childProfileId], references: [id])
  customer         User             @relation(fields: [customerId], references: [id])
  plan             SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([customerId])
  @@index([childProfileId])
  @@index([planId])
  @@index([status])
  @@index([paymentStatus])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@map("subscriptions")
}

model SubscriptionPlan {
  id                            String         @id @default(uuid())
  name                          String
  description                   String?
  price                         Decimal
  priceUSD                      Decimal?       @map("price_usd")
  durationDays                  Int            @map("duration_days")
  features                      String?        @map("features")
  isActive                      Boolean        @default(true) @map("is_active")
  createdAt                     DateTime       @default(now()) @map("created_at")
  updatedAt                     DateTime       @updatedAt @map("updated_at")
  affiliateCommissionPercentage Decimal?       @map("affiliate_commission_percentage")
  subscriptions                 Subscription[]

  @@map("subscription_plans")
}

model Flipbook {
  id            String             @id @default(uuid())
  title         String
  description   String?
  coverImageUrl String?            @map("cover_image_url")
  pdfUrl        String?            @map("pdf_url")
  totalPages    Int?               @map("total_pages")
  category      String?
  isPublished   Boolean            @default(false) @map("is_published")
  isFree        Boolean            @default(false) @map("is_free")
  publishedAt   DateTime?          @map("published_at")
  createdById   String             @map("created_by")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  heyzineUrl    String?            @map("heyzine_url")
  iframeContent String?            @map("iframe_content")
  ageGroup      String?            @map("age_group")
  progress      FlipbookProgress[]
  createdBy     User               @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([category])
  @@index([isPublished])
  @@index([isFree])
  @@index([createdAt])
  @@index([publishedAt])
  @@map("flipbooks")
}

model FlipbookProgress {
  id             String        @id @default(uuid())
  customerId     String        @map("customer_id")
  flipbookId     String        @map("flipbook_id")
  lastPageRead   Int           @map("last_page_read")
  completed      Boolean       @default(false)
  lastAccessedAt DateTime      @default(now()) @map("last_accessed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  childProfileId String?       @map("child_profile_id")
  childProfile   ChildProfile? @relation(fields: [childProfileId], references: [id])
  customer       User          @relation(fields: [customerId], references: [id])
  flipbook       Flipbook      @relation(fields: [flipbookId], references: [id])

  @@unique([customerId, flipbookId], name: "customerId_flipbookId")
  @@unique([childProfileId, flipbookId], name: "childProfileId_flipbookId")
  @@map("flipbook_progress")
}

model Product {
  id                        String   @id @default(uuid())
  title                     String
  description               String?
  productType               String   @map("product_type")
  price                     Decimal
  featuredImageUrl          String?  @map("featured_image_url")
  affiliateCommissionAmount Decimal  @map("affiliate_commission_amount")
  isActive                  Boolean  @default(true) @map("is_active")
  stockQuantity             Int?     @map("stock_quantity")
  digitalFileUrl            String?  @map("digital_file_url")
  requiresCustomization     Boolean  @default(false) @map("requires_customization")
  customizationFields       String?  @map("customization_fields")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  orders                    Order[]

  @@map("products")
}

model Order {
  id                 String   @id @default(uuid())
  orderNumber        String   @unique @map("order_number")
  customerId         String   @map("customer_id")
  productId          String   @map("product_id")
  quantity           Int
  unitPrice          Decimal  @map("unit_price")
  totalAmount        Decimal  @map("total_amount")
  customizationData  String?  @map("customization_data")
  status             String   @default("PENDING")
  paymentStatus      String   @default("PENDING") @map("payment_status")
  paymentReference   String?  @map("payment_reference")
  completedFileUrl   String?  @map("completed_file_url")
  shippingAddress    String?  @map("shipping_address")
  shippingCity       String?  @map("shipping_city")
  shippingState      String?  @map("shipping_state")
  shippingPostalCode String?  @map("shipping_postal_code")
  shippingCountry    String?  @map("shipping_country")
  referredById       String?  @map("referred_by_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  customerUploadUrl  String?  @map("customer_upload_url")
  customer           User     @relation("CustomerOrders", fields: [customerId], references: [id])
  product            Product  @relation(fields: [productId], references: [id])
  referredBy         User?    @relation("AffiliateReferredOrders", fields: [referredById], references: [id])

  @@index([customerId])
  @@index([productId])
  @@index([referredById])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model Commission {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  sourceType String    @map("source_type")
  sourceId   String    @map("source_id")
  amount     Decimal
  currency   String    @default("GHS")
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now()) @map("created_at")
  paidAt     DateTime? @map("paid_at")
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
  @@map("commissions")
}

model PayoutRequest {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  amount        Decimal
  status        String    @default("PENDING")
  requestedAt   DateTime  @default(now()) @map("requested_at")
  processedAt   DateTime? @map("processed_at")
  adminNotes    String?   @map("admin_notes")
  paymentMethod String?   @map("payment_method")
  user          User      @relation(fields: [userId], references: [id])

  @@map("payout_requests")
}

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @map("value")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model ActivityLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  actionType    String   @map("action_type")
  actionDetails String?  @map("action_details")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
  @@map("activity_logs")
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  token       String    @unique
  hashedToken String    @map("hashed_token")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  token       String    @unique
  hashedToken String    @map("hashed_token")
  expiresAt   DateTime  @map("expires_at")
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model ChildProfile {
  id               String             @id @default(uuid())
  parentId         String             @map("parent_id")
  name             String
  ageGroup         String             @map("age_group")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  avatarColor      String             @default("#6366f1") @map("avatar_color")
  dateOfBirth      DateTime?          @map("date_of_birth")
  username         String?            @unique
  readingStreak    Int                @default(0) @map("reading_streak")
  lastReadingDate  DateTime?          @map("last_reading_date")
  badges           Json?              @default("[]")
  loginTokens      ChildLoginToken[]
  parent           User               @relation(fields: [parentId], references: [id], onDelete: Cascade)
  flipbookProgress FlipbookProgress[]
  subscriptions    Subscription[]

  @@index([parentId])
  @@index([ageGroup])
  @@map("child_profiles")
}

model ChildLoginToken {
  id        String       @id @default(uuid())
  childId   String       @map("child_id")
  token     String
  expiresAt DateTime     @map("expires_at")
  createdAt DateTime     @default(now()) @map("created_at")
  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@map("child_login_tokens")
}
