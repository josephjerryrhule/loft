generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String                   @map("password_hash")
  role                    String
  firstName               String?                  @map("first_name")
  lastName                String?                  @map("last_name")
  phoneNumber             String?                  @map("phone_number")
  profilePictureUrl       String?                  @map("profile_picture_url")
  address                 String?
  city                    String?
  state                   String?
  postalCode              String?                  @map("postal_code")
  country                 String?
  managerId               String?                  @map("manager_id")
  inviteCode              String?                  @unique @map("invite_code")
  referredById            String?                  @map("referred_by_id")
  status                  String                   @default("ACTIVE")
  isEmailVerified         Boolean                  @default(false) @map("is_email_verified")
  failedLoginAttempts     Int                      @default(0) @map("failed_login_attempts")
  lastFailedLogin         DateTime?                @map("last_failed_login")
  lockedUntil             DateTime?                @map("locked_until")
  requirePasswordReset    Boolean                  @default(false) @map("require_password_reset")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  ambassadorExpiry        DateTime?                @map("ambassador_expiry")
  ambassadorId            String?                  @unique @map("ambassador_id")
  teamLeaderId            String?                  @map("team_leader_id")
  activityLogs            ActivityLog[]
  childProfiles           ChildProfile[]
  commissions             Commission[]
  emailVerificationTokens EmailVerificationToken[]
  flipbookProgress        FlipbookProgress[]
  createdFlipbooks        Flipbook[]
  invitationsSent         Invitation[]             @relation("Inviter")
  orders                  Order[]                  @relation("CustomerOrders")
  referredOrders          Order[]                  @relation("AffiliateReferredOrders")
  passwordResetTokens     PasswordResetToken[]
  payoutRequests          PayoutRequest[]
  subscriptions           Subscription[]
  manager                 User?                    @relation("ManagerAffiliates", fields: [managerId], references: [id])
  affiliates              User[]                   @relation("ManagerAffiliates")
  referredBy              User?                    @relation("Referrals", fields: [referredById], references: [id])
  referrals               User[]                   @relation("Referrals")
  teamLeader              User?                    @relation("TeamLeaderAffiliates", fields: [teamLeaderId], references: [id])
  teamMembers             User[]                   @relation("TeamLeaderAffiliates")
  payoutMethodType        String?                  @map("payout_method_type")
  payoutDetails           String?                  @map("payout_details")
  payouts                 Payout[]
  manualPayments          ManualPayment[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([managerId])
  @@index([referredById])
  @@index([inviteCode])
  @@index([ambassadorId])
  @@index([createdAt])
  @@map("users")
}

model Invitation {
  id           String    @id @default(uuid())
  inviterId    String    @map("inviter_id")
  inviteeEmail String    @map("invitee_email")
  inviteType   String    @map("invite_type")
  token        String    @unique
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  inviter      User      @relation("Inviter", fields: [inviterId], references: [id])

  @@map("invitations")
}

model Subscription {
  id               String           @id @default(uuid())
  customerId       String           @map("customer_id")
  planId           String           @map("plan_id")
  status           String
  paymentStatus    String           @default("PENDING") @map("payment_status")
  paymentReference String?          @map("payment_reference")
  startDate        DateTime         @map("start_date")
  endDate          DateTime         @map("end_date")
  autoRenew        Boolean          @default(false) @map("auto_renew")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  childProfileId   String?          @map("child_profile_id")
  gateway          String?          @default("PAYSTACK")
  currency         String?          @default("GHS")
  childProfile     ChildProfile?    @relation(fields: [childProfileId], references: [id])
  customer         User             @relation(fields: [customerId], references: [id])
  plan             SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([customerId])
  @@index([childProfileId])
  @@index([planId])
  @@index([status])
  @@index([paymentStatus])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@map("subscriptions")
}

model SubscriptionPlan {
  id                            String         @id @default(uuid())
  name                          String
  description                   String?
  price                         Decimal
  priceUSD                      Decimal?       @map("price_usd")
  durationDays                  Int            @map("duration_days")
  features                      String?        @map("features")
  isActive                      Boolean        @default(true) @map("is_active")
  createdAt                     DateTime       @default(now()) @map("created_at")
  updatedAt                     DateTime       @updatedAt @map("updated_at")
  affiliateCommissionPercentage Decimal?       @map("affiliate_commission_percentage")
  subscriptions                 Subscription[]

  @@map("subscription_plans")
}

model Flipbook {
  id            String             @id @default(uuid())
  title         String
  description   String?
  coverImageUrl String?            @map("cover_image_url")
  pdfUrl        String?            @map("pdf_url")
  totalPages    Int?               @map("total_pages")
  category      String?
  isPublished   Boolean            @default(false) @map("is_published")
  isFree        Boolean            @default(false) @map("is_free")
  publishedAt   DateTime?          @map("published_at")
  createdById   String             @map("created_by")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  heyzineUrl    String?            @map("heyzine_url")
  iframeContent String?            @map("iframe_content")
  ageGroup      String?            @map("age_group")
  progress      FlipbookProgress[]
  createdBy     User               @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([category])
  @@index([isPublished])
  @@index([isFree])
  @@index([createdAt])
  @@index([publishedAt])
  @@map("flipbooks")
}

model FlipbookProgress {
  id             String        @id @default(uuid())
  customerId     String        @map("customer_id")
  flipbookId     String        @map("flipbook_id")
  lastPageRead   Int           @map("last_page_read")
  completed      Boolean       @default(false)
  lastAccessedAt DateTime      @default(now()) @map("last_accessed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  childProfileId String?       @map("child_profile_id")
  childProfile   ChildProfile? @relation(fields: [childProfileId], references: [id])
  customer       User          @relation(fields: [customerId], references: [id])
  flipbook       Flipbook      @relation(fields: [flipbookId], references: [id])

  @@unique([customerId, flipbookId], name: "customerId_flipbookId")
  @@unique([childProfileId, flipbookId], name: "childProfileId_flipbookId")
  @@map("flipbook_progress")
}

model Product {
  id                        String   @id @default(uuid())
  title                     String
  description               String?
  productType               String   @map("product_type")
  price                     Decimal
  featuredImageUrl          String?  @map("featured_image_url")
  affiliateCommissionAmount Decimal  @map("affiliate_commission_amount")
  isActive                  Boolean  @default(true) @map("is_active")
  stockQuantity             Int?     @map("stock_quantity")
  digitalFileUrl            String?  @map("digital_file_url")
  requiresCustomization     Boolean  @default(false) @map("requires_customization")
  customizationFields       String?  @map("customization_fields")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  orders                    Order[]

  @@map("products")
}

model Order {
  id                 String   @id @default(uuid())
  orderNumber        String   @unique @map("order_number")
  customerId         String   @map("customer_id")
  productId          String   @map("product_id")
  quantity           Int
  unitPrice          Decimal  @map("unit_price")
  totalAmount        Decimal  @map("total_amount")
  customizationData  String?  @map("customization_data")
  status             String   @default("PENDING")
  paymentStatus      String   @default("PENDING") @map("payment_status")
  paymentReference   String?  @map("payment_reference")
  completedFileUrl   String?  @map("completed_file_url")
  shippingAddress    String?  @map("shipping_address")
  shippingCity       String?  @map("shipping_city")
  shippingState      String?  @map("shipping_state")
  shippingPostalCode String?  @map("shipping_postal_code")
  shippingCountry    String?  @map("shipping_country")
  referredById       String?  @map("referred_by_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  customerUploadUrl  String?  @map("customer_upload_url")
  customer           User     @relation("CustomerOrders", fields: [customerId], references: [id])
  product            Product  @relation(fields: [productId], references: [id])
  referredBy         User?    @relation("AffiliateReferredOrders", fields: [referredById], references: [id])

  @@index([customerId])
  @@index([productId])
  @@index([referredById])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model Commission {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  sourceType String    @map("source_type")
  sourceId   String    @map("source_id")
  amount     Decimal
  currency   String    @default("GHS")
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now()) @map("created_at")
  paidAt     DateTime? @map("paid_at")
  user              User                      @relation(fields: [userId], references: [id])
  payoutId          String?                   @map("payout_id")
  payout            Payout?                   @relation(fields: [payoutId], references: [id])
  manualAllocations ManualPaymentAllocation[]

  @@index([userId])
  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
  @@map("commissions")
}

model Payout {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  user            User         @relation(fields: [userId], references: [id])
  weekStart       DateTime     @map("week_start")
  weekEnd         DateTime     @map("week_end")
  amountGHS       Decimal      @default(0) @map("amount_ghs")
  amountUSD       Decimal      @default(0) @map("amount_usd")
  status          String       @default("PAYABLE") // "PAYABLE", "APPROVED", "SIGNED", "PAID"
  approvedAt      DateTime?    @map("approved_at")
  approvedBy      String?      @map("approved_by") // admin email/id
  signedAt        DateTime?    @map("signed_at")
  signatureName   String?      @map("signature_name")
  signatureIp     String?      @map("signature_ip")
  paidAt          DateTime?    @map("paid_at")
  paymentMethod   String?      @map("payment_method") // "MOMO" | "BANK"
  paymentRef      String?      @unique @map("payment_ref")
  recipientAcc    String?      @map("recipient_acc")  // Account number paid
  proofUrl        String?      @map("proof_url")      // Uploaded screenshot file path
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  commissions     Commission[]

  @@unique([userId, weekStart, weekEnd])
  @@index([status])
  @@map("payouts")
}

model PayoutRequest {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  amount        Decimal
  status        String    @default("PENDING")
  requestedAt   DateTime  @default(now()) @map("requested_at")
  processedAt   DateTime? @map("processed_at")
  adminNotes    String?   @map("admin_notes")
  paymentMethod String?   @map("payment_method")
  user          User      @relation(fields: [userId], references: [id])

  @@map("payout_requests")
}

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @map("value")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model ActivityLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  actionType    String   @map("action_type")
  actionDetails String?  @map("action_details")
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
  @@map("activity_logs")
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  token       String    @unique
  hashedToken String    @map("hashed_token")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  token       String    @unique
  hashedToken String    @map("hashed_token")
  expiresAt   DateTime  @map("expires_at")
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model ChildProfile {
  id               String             @id @default(uuid())
  parentId         String             @map("parent_id")
  name             String
  ageGroup         String             @map("age_group")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  avatarColor      String             @default("#6366f1") @map("avatar_color")
  dateOfBirth      DateTime?          @map("date_of_birth")
  username         String?            @unique
  readingStreak    Int                @default(0) @map("reading_streak")
  lastReadingDate  DateTime?          @map("last_reading_date")
  badges           Json?              @default("[]")
  loginTokens      ChildLoginToken[]
  parent           User               @relation(fields: [parentId], references: [id], onDelete: Cascade)
  flipbookProgress FlipbookProgress[]
  subscriptions    Subscription[]

  @@index([parentId])
  @@index([ageGroup])
  @@map("child_profiles")
}

model ChildLoginToken {
  id        String       @id @default(uuid())
  childId   String       @map("child_id")
  token     String
  expiresAt DateTime     @map("expires_at")
  createdAt DateTime     @default(now()) @map("created_at")
  child     ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@map("child_login_tokens")
}

model ManualPayment {
  id              String                   @id @default(uuid())
  recipientId     String                   @map("recipient_id")
  recipient       User                     @relation(fields: [recipientId], references: [id])
  paymentType     String                   @map("payment_type")
  totalAmount     Decimal                  @map("total_amount")
  allocatedAmount Decimal                  @default(0) @map("allocated_amount")
  bonusAmount     Decimal                  @default(0) @map("bonus_amount")
  currency        String                   @default("GHS")
  reason          String?
  paymentMethod   String?                  @map("payment_method")
  paymentRef      String?                  @map("payment_ref")
  status          String                   @default("COMPLETED")
  createdById     String                   @map("created_by_id")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  allocations     ManualPaymentAllocation[]

  @@index([recipientId])
  @@index([paymentType])
  @@index([status])
  @@index([createdAt])
  @@map("manual_payments")
}

model ManualPaymentAllocation {
  id              String        @id @default(uuid())
  manualPaymentId String        @map("manual_payment_id")
  manualPayment   ManualPayment @relation(fields: [manualPaymentId], references: [id])
  commissionId    String        @map("commission_id")
  commission      Commission    @relation(fields: [commissionId], references: [id])
  amount          Decimal
  createdAt       DateTime      @default(now()) @map("created_at")

  @@unique([manualPaymentId, commissionId])
  @@index([commissionId])
  @@map("manual_payment_allocations")
}

// ═══════════════════════════════════════════════════════════
// RECRUITMENT SYSTEM MODELS
// ═══════════════════════════════════════════════════════════

model RecruitmentApplicant {
  id                    String                     @id @default(uuid())
  applicantId           String                     @unique @map("applicant_id") // e.g. LOFT-RC-250612-0042
  status                String                     @default("DRAFT") // DRAFT, PENDING_PAYMENT, APPLICATION_SUBMITTED, AWAITING_AUDITION_SLOT_RELEASE, AUDITION_BOOKING_OPEN, AUDITION_SLOT_BOOKED, AUDITION_CONFIRMED, AUDITION_ATTENDED, UNDER_REVIEW, AUDITION_INVITED, SHORTLISTED, SELECTED, REJECTED, HIRED

  // Section 1: Personal Information
  fullName              String                     @map("full_name")
  dateOfBirth           DateTime                   @map("date_of_birth")
  age                   Int
  gender                String                     // MALE, FEMALE, PREFER_NOT_TO_SAY
  phoneNumber           String                     @map("phone_number")
  whatsappNumber        String                     @map("whatsapp_number")
  email                 String?
  residentialArea       String                     @map("residential_area")
  townCity              String                     @map("town_city")
  region                String

  // Section 2: Education
  highestEducation      String                     @map("highest_education") // SHS, DIPLOMA, HND, BACHELORS, MASTERS, OTHER
  institution           String?
  course                String?

  // Section 3: Experience
  workedWithChildren    Boolean                    @map("worked_with_children")
  childrenExperienceDesc String?                   @map("children_experience_desc")
  previousRoles         String                     @map("previous_roles") // JSON array
  relevantExperience    String?                    @map("relevant_experience")

  // Section 4: Communication & Facilitation
  groupSpeakingComfort  String                     @map("group_speaking_comfort") // VERY_COMFORTABLE, COMFORTABLE, SOMEWHAT_COMFORTABLE, NOT_COMFORTABLE
  ledGroupActivity      Boolean                    @map("led_group_activity")
  groupActivityDesc     String?                    @map("group_activity_desc")
  whatMakesLearningFun  String                     @map("what_makes_learning_fun")
  engagementSkills      String                     @map("engagement_skills")

  // Section 5: Short Answers
  whyFacilitator        String                     @map("why_facilitator")
  strengths             String
  problemSolvingExample String                     @map("problem_solving_example")

  // Section 6: Audition Info
  auditionUnderstood    Boolean                    @map("audition_understood")
  willingToTravel       Boolean                    @map("willing_to_travel")

  // Declaration
  declarationAgreed     Boolean                    @map("declaration_agreed")
  declarationName       String                     @map("declaration_name")
  declarationDate       DateTime                   @map("declaration_date")

  // Payment
  paymentStatus         String                     @default("UNPAID") @map("payment_status") // UNPAID, PAID, FAILED
  paymentReference      String?                    @map("payment_reference")
  paymentAmount         Decimal?                   @map("payment_amount")
  paidAt                DateTime?                  @map("paid_at")

  // Admin
  internalNotes         String?                    @map("internal_notes")
  auditionSessionId     String?                    @map("audition_session_id")
  auditionSession       RecruitmentAuditionSession? @relation(fields: [auditionSessionId], references: [id])

  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")

  statusHistory         RecruitmentStatusHistory[]
  auditionScores        RecruitmentAuditionScore[]

  @@index([applicantId])
  @@index([status])
  @@index([paymentStatus])
  @@index([phoneNumber])
  @@index([createdAt])
  @@map("recruitment_applicants")
}

model RecruitmentStatusHistory {
  id          String               @id @default(uuid())
  applicantId String               @map("applicant_id")
  applicant   RecruitmentApplicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  fromStatus  String               @map("from_status")
  toStatus    String               @map("to_status")
  changedBy   String?              @map("changed_by") // admin user ID or "SYSTEM"
  note        String?
  createdAt   DateTime             @default(now()) @map("created_at")

  @@index([applicantId])
  @@index([createdAt])
  @@map("recruitment_status_history")
}

model RecruitmentAuditionEvent {
  id          String                       @id @default(uuid())
  name        String
  date        DateTime
  venue       String
  description String?
  maxCapacity Int?                         @map("max_capacity")
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  sessions    RecruitmentAuditionSession[]

  @@index([date])
  @@map("recruitment_audition_events")
}

model RecruitmentAuditionSession {
  id          String                      @id @default(uuid())
  eventId     String                      @map("event_id")
  event       RecruitmentAuditionEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  startTime   DateTime                    @map("start_time")
  endTime     DateTime                    @map("end_time")
  maxCapacity Int?                        @map("max_capacity")
  createdAt   DateTime                    @default(now()) @map("created_at")

  applicants  RecruitmentApplicant[]
  scores      RecruitmentAuditionScore[]

  @@index([eventId])
  @@map("recruitment_audition_sessions")
}

model RecruitmentAuditionScore {
  id                      String                      @id @default(uuid())
  applicantId             String                      @map("applicant_id")
  applicant               RecruitmentApplicant        @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  sessionId               String?                     @map("session_id")
  session                 RecruitmentAuditionSession? @relation(fields: [sessionId], references: [id])
  evaluatorName           String                      @map("evaluator_name")

  // Scoring categories (1-10 scale)
  readingAbility          Int                         @map("reading_ability")
  storytellingAbility     Int                         @map("storytelling_ability")
  childEngagement         Int                         @map("child_engagement")
  communicationSkills     Int                         @map("communication_skills")
  confidence              Int
  improvisation           Int
  overallRecommendation   Int                         @map("overall_recommendation")
  totalScore              Int                         @map("total_score") // Auto-calculated sum

  evaluatorNotes          String?                     @map("evaluator_notes")
  attended                Boolean                     @default(false)

  createdAt               DateTime                    @default(now()) @map("created_at")
  updatedAt               DateTime                    @updatedAt @map("updated_at")

  @@index([applicantId])
  @@index([sessionId])
  @@map("recruitment_audition_scores")
}
